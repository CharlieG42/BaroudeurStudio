# Fichier d'exemple pour la signature Android
# Copiez ce fichier en key.properties et remplissez les valeurs

# Mot de passe du keystore
storePassword=your_store_password

# Mot de passe de la clé
keyPassword=your_key_password

# Alias de la clé
keyAlias=your_key_alias

# Chemin vers le fichier keystore (relatif à android/app/)
storeFile=your_keystore.jks